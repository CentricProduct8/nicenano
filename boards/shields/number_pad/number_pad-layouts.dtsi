#include <physical_layouts.dtsi>

/ {
    physical_layout_number_pad: physical_layout_number_pad {
        compatible = "zmk,physical-layout";
        display-name = "Number_pad";
        keys  //                     w   h    x    y     rot    rx    ry
            = <&key_physical_attrs 100 100    0    0       0     0     0>
            , <&key_physical_attrs 100 100  125    0       0   125     0>
            , <&key_physical_attrs 100 100  225    0       0   225     0>
            , <&key_physical_attrs 100 100  325    0       0   325     0>
            , <&key_physical_attrs 100 100  425    0       0   425     0>
            , <&key_physical_attrs 100 100    0  125       0     0   125>
            , <&key_physical_attrs 100 100  125  125       0   125   125>
            , <&key_physical_attrs 100 100  225  125       0   225   125>
            , <&key_physical_attrs 100 100  325  125       0   325   125>
            , <&key_physical_attrs 100 100  425  125       0   425   125>
            , <&key_physical_attrs 100 100    0  225       0     0   225>
            , <&key_physical_attrs 100 100  125  225       0   125   225>
            , <&key_physical_attrs 100 100  225  225       0   225   225>
            , <&key_physical_attrs 100 100  325  225       0   325   225>
            , <&key_physical_attrs 100 200  425  225       0   425   225>
            , <&key_physical_attrs 100 100    0  325       0     0   325>
            , <&key_physical_attrs 100 100  125  325       0   125   325>
            , <&key_physical_attrs 100 100  225  325       0   225   325>
            , <&key_physical_attrs 100 100  325  325       0   325   325>
            , <&key_physical_attrs 100 100    0  425       0     0   425>
            , <&key_physical_attrs 100 100  125  425       0   125   425>
            , <&key_physical_attrs 100 100  225  425       0   225   425>
            , <&key_physical_attrs 100 100  325  425       0   325   425>
            , <&key_physical_attrs 100 200  425  425       0   425   425>
            , <&key_physical_attrs 100 100    0  525       0     0   525>
            , <&key_physical_attrs 200 100  125  525       0   125   525>
            , <&key_physical_attrs 100 100  325  525       0   325   525>
            ;
    };
};
